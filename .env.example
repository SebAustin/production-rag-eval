# production-rag-eval — environment variables
# Copy to .env and fill in. Never commit .env.

# --- API keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...
VOYAGE_API_KEY=...

# --- HuggingFace (optional, for dataset download) ---
HF_TOKEN=

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=financebench_v1

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Retrieval ---
BM25_TOP_K=50
DENSE_TOP_K=50
RERANK_TOP_N=10

# --- Conformal abstention ---
CONFORMAL_ALPHA=0.10

# --- Models ---
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6

# --- Cost guardrails ---
MAX_API_SPEND_USD=10.0
EVAL_COST_CAP_USD=5.00
